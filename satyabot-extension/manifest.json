{
  "manifest_version": 3,
  "name": "SatyaBot - Misinformation Checker",
  "version": "1.0",
  "description": "Fact-checking misinformation tool.",
  "permissions": [
    "contextMenus",
    "notifications"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils/api.js", "content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "host_permissions": [
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}